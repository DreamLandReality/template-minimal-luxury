---
export interface Props {
  data: {
    sectionEyebrow?: string;
    sectionTitle?: string;
    items: Array<{
      name: string;
      photo?: string;
      text: string;
      rating: number;
    }>;
  };
}

const { data } = Astro.props;
const imgSrc = (path: string) => path?.startsWith('http') ? path : `/${path}`;
---

<section class="py-20 px-6 bg-stone-50" data-dr-section="testimonials">
  <div class="max-w-6xl mx-auto">
    {data.sectionEyebrow && (
      <p class="text-xs uppercase tracking-widest text-muted mb-2 text-center" data-dr-field="sectionEyebrow">
        {data.sectionEyebrow}
      </p>
    )}
    {data.sectionTitle && (
      <h2 class="text-3xl md:text-4xl font-serif text-center mb-12" data-dr-field="sectionTitle">
        {data.sectionTitle}
      </h2>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-dr-list="testimonials">
      {data.items.map((item, index) => (
        <div class="bg-surface p-8" data-dr-list-item data-dr-index={index}>
          <div class="flex items-center mb-4">
            {item.photo ? (
              <img
                src={imgSrc(item.photo)}
                alt={item.name}
                class="w-12 h-12 rounded-full object-cover mr-4"
                data-dr-field="photo"
              />
            ) : (
              <div class="w-12 h-12 rounded-full bg-stone-200 mr-4 flex items-center justify-center">
                <span class="text-stone-600 font-serif text-lg">{item.name.charAt(0)}</span>
              </div>
            )}
            <div>
              <h4 class="font-serif" data-dr-field="name">{item.name}</h4>
              <div class="flex text-amber-500 text-sm">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg
                    class={`w-4 h-4 ${i < item.rating ? 'fill-current' : 'fill-stone-300'}`}
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <p class="text-muted italic" data-dr-field="text">"{item.text}"</p>
        </div>
      ))}
    </div>
  </div>
</section>
